APP_NAME=DocuCast
APP_ENV=production
APP_KEY=base64:Of0nhMRs6WznQLei8JSR9bUpQ/y1H0tvt7O1kytIZus=
APP_DEBUG=false
APP_URL=https://docucast.bionic-natura.cloud

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# Database Configuration (Docker)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=docucast
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Traefik Configuration
TRAEFIK_NETWORK=traefik_default
TRAEFIK_HOST=docucast.bionic-natura.cloud
TRAEFIK_ENTRYPOINTS=websecure
TRAEFIK_TLS=true

# Session Configuration
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Broadcasting - Reverb WebSocket
BROADCAST_DRIVER=reverb
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=docucast
REVERB_APP_KEY=docucast-app-key
REVERB_APP_SECRET=docucast-app-secret
REVERB_HOST=docucast.bionic-natura.cloud
REVERB_PORT=443
REVERB_SCHEME=https

# Vite build-time variables (baked into frontend JS bundle)
VITE_REVERB_APP_KEY=docucast-app-key
VITE_REVERB_HOST=${REVERB_HOST}
VITE_REVERB_PORT=${REVERB_PORT}
VITE_REVERB_SCHEME=${REVERB_SCHEME}

# Filesystem Configuration
FILESYSTEM_DISK=local

# Queue Configuration
QUEUE_CONNECTION=redis

# Cache Configuration
CACHE_STORE=redis
CACHE_PREFIX=docucast

# Redis Configuration
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail Configuration
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# AWS Configuration (if using S3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Vite Configuration
VITE_APP_NAME="${APP_NAME}"
